# ============================================================
# .gitignore — Databricks Insurance Fraud Detection Pipeline
# M Priyadarsini 
# ============================================================

# Environment files — never commit credentials
.env
.env.local
*.env

# Databricks connection files
.databrickscfg
databricks.yml

# Python artifacts (if notebooks exported)
__pycache__/
*.py[cod]
*.pyo
.ipynb_checkpoints/
*.ipynb~

# Jupyter notebooks with output (strip outputs before committing)
# Uncomment if using notebooks:
# *.ipynb

# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Windows system files
Thumbs.db
Desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp

# Data files — never commit real client data
*.csv
*.xlsx
*.json
*.parquet
data/raw/
data/sensitive/
